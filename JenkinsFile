pipeline {

  agent any


  environment {

    DOCKER_CREDENTIALS = credentials('docker-credentials')

    DOCKER_USER = "${DOCKER_CREDENTIALS_USR}"
    DOCKER_PASS = "${DOCKER_CREDENTIALS_PSW}"


    REPO_BACKEND = "${DOCKER_USER}/hotstar-backend:${BUILD_NUMBER}"
    REPO_FRONTEND = "${DOCKER_USER}/hotstar-frontend:${BUILD_NUMBER}"


    SONAR_TOKEN = credentials('sonarqube')

    SONAR_URL = "http://3.84.111.82:9000"

    SONAR_SCANNER = "/opt/sonar-scanner/bin/sonar-scanner"


    GIT_CREDENTIALS = credentials('github-credentials')

    GIT_USER = "${GIT_CREDENTIALS_USR}"
    GIT_PSWD = "${GIT_CREDENTIALS_PSW}"

  }


  stages {


    stage('Checkout') {

      steps {

        checkout([
          $class: 'GitSCM',
          branches: [[name: '*/main']],
          userRemoteConfigs: [[
            url: 'https://github.com/Rohsun/Hotstarapplication-deploy',
            credentialsId: 'github-credentials'
          ]]
        ])

      }

    }



    stage('SonarQube Analysis') {

      steps {

        sh """

        ${SONAR_SCANNER} \
        -Dsonar.projectKey=hotstar-app \
        -Dsonar.projectName=hotstar-app \
        -Dsonar.sources=backend,frontend \
        -Dsonar.host.url=${SONAR_URL} \
        -Dsonar.login=${SONAR_TOKEN}

        """

      }

    }



    stage('Build & Push Docker Images') {

      steps {

        sh '''

        docker build -t $REPO_BACKEND ./backend


        docker build -t $REPO_FRONTEND ./frontend


        echo "$DOCKER_PASS" | docker login \
        -u "$DOCKER_USER" \
        --password-stdin


        docker push $REPO_BACKEND


        docker push $REPO_FRONTEND


        '''

      }

    }



    stage('Update Manifests') {

      steps {

        sh '''

        git config user.name "jenkins"

        git config user.email "jenkins@ci"


        git checkout -B main


        git pull origin main --rebase


        sed -i "s|image: .*hotstar-backend.*|image: $REPO_BACKEND|" manifests/backend-deployment.yaml


        sed -i "s|image: .*hotstar-frontend.*|image: $REPO_FRONTEND|" manifests/frontend-deployment.yaml


        git add manifests/*.yaml


        git commit -m "Update images to build $BUILD_NUMBER [skip ci]" || echo "No changes"


        git push https://$GIT_USER:$GIT_PSWD@github.com/Rohsun/Hotstarapplication-deploy main


        '''

      }

    }


  }


}
